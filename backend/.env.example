# LORA backend environment configuration
# Copy this file to .env and fill in your values.
# All variables are optional — defaults are shown.

# ── Foundry model IDs ──────────────────────────────────────────────────────
# Must match the IDs returned by GET /v1/models on your Foundry instance.
LORA_CHAT_MODEL=Phi-4-mini-instruct-generic-gpu:5
LORA_EMBEDDING_MODEL=text-embedding-3-small

# ── Foundry network ────────────────────────────────────────────────────────
# Leave blank to auto-resolve from `foundry service status` at startup.
LORA_FOUNDRY_URL=
LORA_STREAM_TIMEOUT=60.0
LORA_REQUEST_TIMEOUT=30.0

# ── Corpus paths ───────────────────────────────────────────────────────────
# Absolute paths.  Leave blank to use <backend>/wiki, <backend>/raw, etc.
LORA_WIKI_DIR=
LORA_RAW_DIR=
LORA_SCHEMA_PATH=
LORA_TEMPLATES_DIR=

# ── Agent behaviour ────────────────────────────────────────────────────────
# Set to true to have WikiAgent write wiki pages to disk immediately.
# When false (default), proposed changes are returned for review.
LORA_AUTO_APPLY=false

# ── Logging ────────────────────────────────────────────────────────────────
LORA_LOG_LEVEL=INFO
