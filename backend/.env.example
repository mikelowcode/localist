# LOCALIST backend environment configuration
# Copy this file to .env and fill in your values.
# All variables are optional — defaults are shown.

# ── Runtime backend selection ─────────────────────────────────────────────
# Which BaseRuntimeClient implementation to construct at startup: foundry,
# omlx, or ollama (see runtime_factory.py's _REGISTRY). Swapping this is the
# only change needed to move between backends.
LOCALIST_RUNTIME_BACKEND=foundry

# ── Foundry model IDs ──────────────────────────────────────────────────────
# Must match the IDs returned by GET /v1/models on your Foundry instance.
LOCALIST_CHAT_MODEL=Phi-4-mini-instruct-generic-gpu:5
LOCALIST_EMBEDDING_MODEL=text-embedding-3-small

# ── Foundry network ────────────────────────────────────────────────────────
# Leave blank to auto-resolve from `foundry service status` at startup.
LOCALIST_FOUNDRY_URL=
LOCALIST_STREAM_TIMEOUT=60.0
LOCALIST_REQUEST_TIMEOUT=30.0

# ── Corpus paths ───────────────────────────────────────────────────────────
# Absolute paths.  Leave blank to use <backend>/wiki, <backend>/raw, etc.
LOCALIST_WIKI_DIR=
LOCALIST_RAW_DIR=
LOCALIST_SCHEMA_PATH=
LOCALIST_TEMPLATES_DIR=

# ── Agent behaviour ────────────────────────────────────────────────────────
# Set to true to have WikiAgent write wiki pages to disk immediately.
# When false (default), proposed changes are returned for review.
LOCALIST_AUTO_APPLY=false

# ── Episodic write-approval gate ──────────────────────────────────────────
# When true, model_extracted (implicit) episodes are staged as "pending"
# instead of going live immediately — approve/reject via
# POST /memory/episodes/{id}/approve|reject. Explicit "remember that..."
# episodes are never gated. Default false (unchanged behaviour).
LOCALIST_EPISODIC_WRITE_APPROVAL=false

# ── Research loop ──────────────────────────────────────────────────────────
# Upgrade web_search -> the research loop (search/evaluate/fetch/reformulate,
# see mcp_tool_dispatcher.py._run_research_loop) when the instruction's
# cosine similarity to the research_intent template group clears
# _RESEARCH_INTENT_THRESHOLD (planner.py). Off by default.
LOCALIST_RESEARCH_LOOP_ENABLED=false

# ── MCP server (localist-mcp, port 8003) ──────────────────────────────────
# Base URL the backend's MCPToolDispatcher connects to (/sse is appended
# automatically). Only needs to change if localist-mcp runs on a different
# host/port than the default started by start_localist.sh.
LOCALIST_MCP_URL=http://localhost:8003
# Sandbox root for file_op tools (read_file/write_file/append_file), read by
# localist-mcp itself, not the main backend process. Leave blank to default
# to backend/ (parent of the mcp_server/ package) — file_op reads/writes are
# further sandboxed under a generated_files/ subdirectory of this root.
LOCALIST_MCP_PROJECT_ROOT=

# ── External APIs ──────────────────────────────────────────────────────────
# web_search (localist-mcp) uses exactly one provider, chosen here.
# SEARCH_PROVIDER=langsearch (default) or brave.
SEARCH_PROVIDER=langsearch
LANGSEARCH_API_KEY=
BRAVE_API_KEY=

# ── Logging ────────────────────────────────────────────────────────────────
LOCALIST_LOG_LEVEL=INFO
